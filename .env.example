# Absolute path for generated reports (e.g. `samgraha audit --report`).
# Unset falls back to <repo>/docs/raw/reports.
# SAMGRAHA_REPORT_DIR=

# Absolute path to this repository's documentation root.
# Unset falls back to <repo>/docs.
# SAMGRAHA_DOCS_DIR=

# Absolute path to this repository's implementation/source directory.
# Reserved for future traceability checks; unset falls back to <repo>/src.
# SAMGRAHA_IMPLEMENTATION_DIR=

# Absolute path to this repository's external scripts directory.
# Only relevant if [repository.scripts] is set in samgraha.toml.
# SAMGRAHA_SCRIPTS_DIR=

# Absolute path to this repository's test directory, if kept outside
# implementation.dir. Only relevant if [repository.tests] is set.
# SAMGRAHA_TESTS_DIR=

# Copy this file to .env and uncomment the values to configure:
#   cp .env.example .env
